#include "fc_motor.h"
#include "main.h" // Include main.h để lấy cái handle htim2 của HAL

// Lấy biến htim2 từ main.c sang
extern TIM_HandleTypeDef htim2;

// Mặc định vừa bật nguồn là phải DISARM
volatile FC_MotorState_t motor_state = MOTOR_DISARMED;

void FC_Motor_Init(void) {
    // Kích hoạt 4 kênh PWM của TIM2 cho 4 ESC
    HAL_TIM_PWM_Start(&htim2, TIM_CHANNEL_1);
    HAL_TIM_PWM_Start(&htim2, TIM_CHANNEL_2);
    HAL_TIM_PWM_Start(&htim2, TIM_CHANNEL_3);
    HAL_TIM_PWM_Start(&htim2, TIM_CHANNEL_4);

    // Ép cứng tín hiệu về mức tắt motor ngay khi khởi động
    FC_Motor_Disarm();
}

void FC_Motor_Arm(void) {
    motor_state = MOTOR_ARMED;
    // Tùy chọn: Khi Arm, cho motor quay ở mức idle (ví dụ 1050us)
    // để báo hiệu cho người lái biết là drone đã sẵn sàng.
    __HAL_TIM_SET_COMPARE(&htim2, TIM_CHANNEL_1, 1050);
    __HAL_TIM_SET_COMPARE(&htim2, TIM_CHANNEL_2, 1050);
    __HAL_TIM_SET_COMPARE(&htim2, TIM_CHANNEL_3, 1050);
    __HAL_TIM_SET_COMPARE(&htim2, TIM_CHANNEL_4, 1050);
}

void FC_Motor_Disarm(void) {
    motor_state = MOTOR_DISARMED;
    // Ép về 1000us (Mức tắt motor chuẩn của ESC)
    __HAL_TIM_SET_COMPARE(&htim2, TIM_CHANNEL_1, 1000);
    __HAL_TIM_SET_COMPARE(&htim2, TIM_CHANNEL_2, 1000);
    __HAL_TIM_SET_COMPARE(&htim2, TIM_CHANNEL_3, 1000);
    __HAL_TIM_SET_COMPARE(&htim2, TIM_CHANNEL_4, 1000);
}

void FC_Motor_SetPWM(uint16_t m1, uint16_t m2, uint16_t m3, uint16_t m4) {
    // : Nếu chưa Arm mà có lệnh set PWM (do lỗi PID chẳng hạn) thì chặn ngay
    if (motor_state == MOTOR_DISARMED) {
        return;
    }

    // Nếu đã Arm, cho phép cập nhật xung ra 4 ESC
    __HAL_TIM_SET_COMPARE(&htim2, TIM_CHANNEL_1, m1);
    __HAL_TIM_SET_COMPARE(&htim2, TIM_CHANNEL_2, m2);
    __HAL_TIM_SET_COMPARE(&htim2, TIM_CHANNEL_3, m3);
    __HAL_TIM_SET_COMPARE(&htim2, TIM_CHANNEL_4, m4);
}
