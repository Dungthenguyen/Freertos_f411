#include "fc_motor.h"
#include "main.h"

extern TIM_HandleTypeDef htim2;

static uint16_t clamp_u16(uint16_t x, uint16_t min, uint16_t max)
{
    if (x < min) return min;
    if (x > max) return max;
    return x;
}

void FC_Motor_Init(void)
{
    Motor_StopAll();
}

void Motor_Write_us(uint16_t m1, uint16_t m2, uint16_t m3, uint16_t m4)
{
    m1 = clamp_u16(m1, 1000, 2000);
    m2 = clamp_u16(m2, 1000, 2000);
    m3 = clamp_u16(m3, 1000, 2000);
    m4 = clamp_u16(m4, 1000, 2000);

    __HAL_TIM_SET_COMPARE(&htim2, TIM_CHANNEL_1, m1);
    __HAL_TIM_SET_COMPARE(&htim2, TIM_CHANNEL_2, m2);
    __HAL_TIM_SET_COMPARE(&htim2, TIM_CHANNEL_3, m3);
    __HAL_TIM_SET_COMPARE(&htim2, TIM_CHANNEL_4, m4);
}

void Motor_StopAll(void)
{
    Motor_Write_us(1000, 1000, 1000, 1000);
}
