#include "fc_mpu6050.h"
#include "main.h"
#include "cmsis_os.h"
extern I2C_HandleTypeDef hi2c1;
extern osThreadId pidTaskHandle;
// Địa chỉ I2C của MPU6050 (Dịch trái 1 bit theo chuẩn HAL)
#define MPU6050_ADDR 0xD0

// Mảng đệm để DMA ném 14 byte đọc được vào đây
uint8_t mpu_rx_buffer[14];

MPU6050_t mpu_data;

void FC_MPU6050_Init(void) {
    uint8_t check;
    uint8_t Data;

    // 1. Kiểm tra xem MPU6050 có phản hồi không (Đọc thanh ghi WHO_AM_I)
    HAL_I2C_Mem_Read(&hi2c1, MPU6050_ADDR, 0x75, 1, &check, 1, 1000);

    if (check == 104) { // 104 (0x68) là mã chuẩn của MPU6050
        // Đánh thức cảm biến (Ghi 0 vào thanh ghi PWR_MGMT_1)
        Data = 0;
        HAL_I2C_Mem_Write(&hi2c1, MPU6050_ADDR, 0x6B, 1, &Data, 1, 1000);

        // Cấu hình tần số lấy mẫu (SMPLRT_DIV) - Đang set = 1kHz
        Data = 0x07;
        HAL_I2C_Mem_Write(&hi2c1, MPU6050_ADDR, 0x19, 1, &Data, 1, 1000);

        // Cấu hình Gyro (+/- 500 deg/s)
        Data = 0x08;
        HAL_I2C_Mem_Write(&hi2c1, MPU6050_ADDR, 0x1B, 1, &Data, 1, 1000);

        // Cấu hình Accel (+/- 8g)
        Data = 0x10;
        HAL_I2C_Mem_Write(&hi2c1, MPU6050_ADDR, 0x1C, 1, &Data, 1, 1000);
    }
}

// Hàm này được gọi định kỳ (ví dụ mỗi 1ms) để kích hoạt quá trình đọc không cản trở CPU
void FC_MPU6050_Read_DMA(void) {
    // Yêu cầu DMA chép 14 byte từ địa chỉ 0x3B (ACCEL_XOUT_H) vào mảng mpu_rx_buffer
    HAL_I2C_Mem_Read_DMA(&hi2c1, MPU6050_ADDR, 0x3B, 1, mpu_rx_buffer, 14);
}

// ======================================================================
// NGẮT: Hàm này TỰ ĐỘNG CHẠY khi DMA đã chép xong 14 byte dữ liệu
// ======================================================================
void HAL_I2C_MemRxCpltCallback(I2C_HandleTypeDef *hi2c) {
    if (hi2c->Instance == I2C1) {
        // MPU6050 trả về 16-bit cho mỗi trục, bị chia thành 2 byte (High và Low)
        // Ta cần ghép chúng lại với nhau
        mpu_data.Accel_X_RAW = (int16_t)(mpu_rx_buffer[0] << 8 | mpu_rx_buffer[1]);
        mpu_data.Accel_Y_RAW = (int16_t)(mpu_rx_buffer[2] << 8 | mpu_rx_buffer[3]);
        mpu_data.Accel_Z_RAW = (int16_t)(mpu_rx_buffer[4] << 8 | mpu_rx_buffer[5]);

        // Byte 6 và 7 là nhiệt độ, ta bỏ qua

        mpu_data.Gyro_X_RAW = (int16_t)(mpu_rx_buffer[8] << 8 | mpu_rx_buffer[9]);
        mpu_data.Gyro_Y_RAW = (int16_t)(mpu_rx_buffer[10] << 8 | mpu_rx_buffer[11]);
        mpu_data.Gyro_Z_RAW = (int16_t)(mpu_rx_buffer[12] << 8 | mpu_rx_buffer[13]);

        // Chuyển đổi ra đơn vị vật lý (Dựa theo dải đo +/-500dps và +/-8g đã setup)
        mpu_data.Ax = mpu_data.Accel_X_RAW / 4096.0;
        mpu_data.Ay = mpu_data.Accel_Y_RAW / 4096.0;
        mpu_data.Az = mpu_data.Accel_Z_RAW / 4096.0;

        mpu_data.Gx = mpu_data.Gyro_X_RAW / 65.5;
        mpu_data.Gy = mpu_data.Gyro_Y_RAW / 65.5;
        mpu_data.Gz = mpu_data.Gyro_Z_RAW / 65.5;

        // Cực kỳ quan trọng:
        // Đáng lý ra ở đây chúng ta sẽ đánh thức PID Task hoạt động,
        // vì PID chỉ nên chạy ngay khi vừa có data tươi nhất từ cảm biến.

        BaseType_t xHigherPriorityTaskWoken = pdFALSE;
                vTaskNotifyGiveFromISR(pidTaskHandle, &xHigherPriorityTaskWoken);
                portYIELD_FROM_ISR(xHigherPriorityTaskWoken);
    }
}
